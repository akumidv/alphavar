# Copy to `test.env` (gitignored) and fill in as needed. All variables are OPTIONAL.

# Local market-data root. Leave UNSET to use the committed hermetic fixtures
# (tests/fixtures/data) — a clean checkout is green without this. Point it at your full
# local data tree for richer runs:
# DATA_PATH=/abs/path/to/data

# ETL timeframe used by ETL tests/tools.
ETL_TIMEFRAME=5m

# Telegram notifications (only for messenger integration runs).
# TG_BOT_TOKEN=
# TG_CHAT=
